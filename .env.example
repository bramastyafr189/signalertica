# Database Configuration
# Fallback is a local SQLite database: 'file:signalertica.db'
TURSO_CONNECTION_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# Web Push Notifications (VAPID keys)
# Generate them using: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_public_vapid_key
VAPID_PRIVATE_KEY=your_private_vapid_key

# Cron Job Security (for securing /api/cron/scan in production)
CRON_SECRET=your_cron_job_secret_token
